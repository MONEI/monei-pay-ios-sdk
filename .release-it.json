{
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore: release v${version}"
  },
  "github": {
    "release": true
  },
  "npm": false,
  "hooks": {
    "before:init": ["swift test"],
    "after:bump": [
      "sed -i '' \"s/s.version.*=.*/s.version      = '${version}'/\" MoneiPaySDK.podspec"
    ]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
